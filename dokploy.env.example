# Dokploy deployment example
# Copy these values into Dokploy environment variables before deploying
# This compose file configures Traefik routing directly, so set your public domain here before deploying.

POSTGRES_DB=diffmint
POSTGRES_USER=diffmint
POSTGRES_PASSWORD=change-this-password
# Keep DATABASE_URL aligned with the Postgres credentials above unless you use an external DB.
DATABASE_URL=postgres://diffmint:change-this-password@postgres:5432/diffmint

DIFFMINT_APP_URL=https://diffmint.example.com
NEXT_PUBLIC_APP_URL=https://diffmint.example.com
NEXT_PUBLIC_SITE_URL=https://diffmint.example.com
DOKPLOY_DOMAIN=diffmint.example.com
TRAEFIK_ENTRYPOINT=websecure
TRAEFIK_CERT_RESOLVER=letsencrypt

NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_live_xxx
CLERK_SECRET_KEY=sk_live_xxx
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/auth/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/auth/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/dashboard/overview
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/dashboard/overview

POLAR_SERVER=sandbox
POLAR_ACCESS_TOKEN=
POLAR_WEBHOOK_SECRET=
POLAR_WEBHOOK_MAX_BYTES=262144
POLAR_PRODUCT_ID_PRO=
POLAR_PRODUCT_ID_TEAM=
POLAR_PRODUCT_ID_ENTERPRISE=

DIFFMINT_RELEASE_SIGNING_PRIVATE_KEY=
DIFFMINT_RELEASE_SIGNING_KEY_ID=diffmint-release
DIFFMINT_ENABLE_HSTS=true
