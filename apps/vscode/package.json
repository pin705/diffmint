{
  "name": "diffmint-vscode",
  "displayName": "Diffmint",
  "version": "0.1.0",
  "private": true,
  "description": "Policy-driven local-first code review in VS Code through the Diffmint CLI.",
  "categories": [
    "Other"
  ],
  "keywords": [
    "ai",
    "cli",
    "git",
    "policy",
    "review"
  ],
  "publisher": "diffmint",
  "main": "./dist/extension.js",
  "scripts": {
    "clean": "rm -rf dist",
    "build": "tsc -p .",
    "watch": "tsc -w -p .",
    "package": "pnpm build && pnpm dlx @vscode/vsce package --allow-missing-repository --no-dependencies"
  },
  "devDependencies": {
    "@types/node": "22.10.2",
    "@types/vscode": "^1.95.0",
    "typescript": "5.7.2"
  },
  "contributes": {
    "commands": [
      {
        "command": "diffmint.reviewCurrentChanges",
        "title": "Diffmint: Review Current Changes"
      },
      {
        "command": "diffmint.reviewStagedChanges",
        "title": "Diffmint: Review Staged Changes"
      },
      {
        "command": "diffmint.reviewSelectedFiles",
        "title": "Diffmint: Review Selected Files"
      },
      {
        "command": "diffmint.explainCurrentFile",
        "title": "Diffmint: Explain Current File"
      },
      {
        "command": "diffmint.generateTests",
        "title": "Diffmint: Generate Tests for Current File"
      },
      {
        "command": "diffmint.openHistory",
        "title": "Diffmint: Open Review History"
      },
      {
        "command": "diffmint.openTeamRules",
        "title": "Diffmint: Open Team Rules"
      },
      {
        "command": "diffmint.openDashboard",
        "title": "Diffmint: Open Dashboard"
      },
      {
        "command": "diffmint.refreshViews",
        "title": "Diffmint: Refresh Views"
      },
      {
        "command": "diffmint.showLatestResult",
        "title": "Diffmint: Show Latest Result"
      },
      {
        "command": "diffmint.signIn",
        "title": "Diffmint: Sign In / Switch Workspace"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "diffmint",
          "title": "Diffmint",
          "icon": "media/diffmint.svg"
        }
      ]
    },
    "views": {
      "diffmint": [
        {
          "id": "diffmint.results",
          "name": "Review Results"
        },
        {
          "id": "diffmint.history",
          "name": "History"
        },
        {
          "id": "diffmint.workspace",
          "name": "Workspace"
        }
      ]
    },
    "menus": {
      "explorer/context": [
        {
          "command": "diffmint.reviewSelectedFiles",
          "when": "resourceScheme == file",
          "group": "navigation"
        }
      ],
      "editor/context": [
        {
          "command": "diffmint.reviewSelectedFiles",
          "when": "resourceScheme == file",
          "group": "navigation"
        },
        {
          "command": "diffmint.explainCurrentFile",
          "when": "resourceScheme == file",
          "group": "navigation"
        },
        {
          "command": "diffmint.generateTests",
          "when": "resourceScheme == file",
          "group": "navigation"
        }
      ],
      "view/title": [
        {
          "command": "diffmint.refreshViews",
          "when": "view == diffmint.results",
          "group": "navigation"
        },
        {
          "command": "diffmint.refreshViews",
          "when": "view == diffmint.history",
          "group": "navigation"
        },
        {
          "command": "diffmint.refreshViews",
          "when": "view == diffmint.workspace",
          "group": "navigation"
        }
      ]
    },
    "configuration": {
      "title": "Diffmint",
      "properties": {
        "diffmint.cliPath": {
          "type": "string",
          "default": "dm",
          "description": "Path to the `dm` CLI binary used by the Diffmint extension."
        },
        "diffmint.webBaseUrl": {
          "type": "string",
          "default": "https://diffmint.io",
          "description": "Base URL for the Diffmint web control plane."
        }
      }
    }
  },
  "activationEvents": [
    "onCommand:diffmint.explainCurrentFile",
    "onCommand:diffmint.generateTests",
    "onCommand:diffmint.openDashboard",
    "onCommand:diffmint.openHistory",
    "onCommand:diffmint.openTeamRules",
    "onCommand:diffmint.refreshViews",
    "onCommand:diffmint.reviewCurrentChanges",
    "onCommand:diffmint.reviewSelectedFiles",
    "onCommand:diffmint.reviewStagedChanges",
    "onCommand:diffmint.showLatestResult",
    "onCommand:diffmint.signIn"
  ],
  "engines": {
    "vscode": "^1.95.0"
  }
}
