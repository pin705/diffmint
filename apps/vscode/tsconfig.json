{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "module": "commonjs",
    "moduleResolution": "node",
    "target": "ES2020",
    "lib": ["ES2020"],
    "outDir": "dist",
    "rootDir": "src",
    "noEmit": false,
    "sourceMap": true,
    "strict": true,
    "baseUrl": ".",
    "paths": {
      "@diffmint/contracts": ["../../packages/contracts/src/index.ts"],
      "@diffmint/docs-content": ["../../packages/docs-content/src/index.ts"],
      "@diffmint/policy-engine": ["../../packages/policy-engine/src/index.ts"],
      "@diffmint/review-core": ["../../packages/review-core/src/index.ts"]
    }
  },
  "include": ["src/**/*.ts"]
}
