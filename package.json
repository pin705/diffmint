{
  "name": "diffmint",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.12.4",
  "scripts": {
    "dev": "pnpm dev:web",
    "dev:web": "pnpm --dir apps/web dev",
    "dev:cli": "pnpm --dir apps/cli dev",
    "build": "pnpm build:web",
    "build:web": "pnpm --dir apps/web build",
    "build:vscode": "pnpm --dir apps/vscode build",
    "package:vscode": "pnpm --dir apps/vscode package",
    "start": "pnpm start:web",
    "start:web": "pnpm --dir apps/web start",
    "db:generate": "pnpm --dir apps/web db:generate",
    "db:migrate": "pnpm --dir apps/web db:migrate",
    "db:seed": "pnpm --dir apps/web db:seed",
    "db:studio": "pnpm --dir apps/web db:studio",
    "docker:dev": "docker compose up --build",
    "docker:dev:down": "docker compose down --remove-orphans",
    "docker:dev:logs": "docker compose logs -f web postgres",
    "docker:dev:reset": "docker compose down --volumes --remove-orphans",
    "lint": "oxlint .",
    "lint:fix": "oxlint --fix . && pnpm format",
    "lint:strict": "oxlint --deny-warnings .",
    "format": "oxfmt --write .",
    "format:check": "oxfmt --check .",
    "test": "pnpm test:unit && pnpm test:e2e",
    "test:unit": "vitest run",
    "test:unit:watch": "vitest",
    "test:e2e": "DIFFMINT_DISABLE_CLERK=true NEXT_PUBLIC_DIFFMINT_DISABLE_CLERK=true pnpm build:web && DIFFMINT_DISABLE_CLERK=true NEXT_PUBLIC_DIFFMINT_DISABLE_CLERK=true playwright test",
    "test:e2e:install": "playwright install chromium",
    "typecheck": "pnpm typecheck:web && pnpm typecheck:cli && pnpm typecheck:vscode",
    "typecheck:web": "rm -rf apps/web/.next && pnpm exec tsc -p apps/web/tsconfig.json --noEmit",
    "typecheck:cli": "pnpm exec tsc -p apps/cli/tsconfig.json --noEmit",
    "typecheck:vscode": "pnpm exec tsc -p apps/vscode/tsconfig.json --noEmit",
    "docs:check": "pnpm --dir apps/web docs:check",
    "check": "pnpm typecheck && pnpm docs:check",
    "prepare": "husky"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@types/node": "22.10.2",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "husky": "^9.1.7",
    "lint-staged": "^15.5.2",
    "oxfmt": "^0.42.0",
    "oxlint": "^1.57.0",
    "tsx": "^4.19.2",
    "typescript": "5.7.2",
    "vitest": "^4.1.4"
  },
  "overrides": {
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3"
  },
  "lint-staged": {
    "!(scripts)/**/*.{js,jsx,tsx,ts,css,less,scss,sass,md,mdx,json}": [
      "oxfmt --write"
    ]
  }
}
